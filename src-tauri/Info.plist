<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Menubar-only agent: hide the Dock icon and the app menu bar.
	     Paired with ActivationPolicy::Accessory set in lib.rs setup(); this key
	     makes the *bundled* .app Dock-less even before Rust runs. -->
	<key>LSUIElement</key>
	<true/>
</dict>
</plist>
