# WARDEN is fully local. It reads your on-disk agent transcripts and needs no API
# keys and no network access. Everything below is OPTIONAL: the defaults work out of
# the box on macOS. Copy this to a project-local `.env` (gitignored) only if you need
# to override a path.

# Where WARDEN keeps its SQLite index of ingested transcript metadata.
WARDEN_DB_PATH=~/.warden/warden.db

# Transcript roots. Override only if your harnesses write somewhere non-standard.
WARDEN_CLAUDE_PROJECTS=~/.claude/projects
WARDEN_CODEX_SESSIONS=~/.codex/sessions
