# WARDEN brain - Near AI cloud (OpenAI-compatible Chat Completions).
# Fill these in your project-local .env (gitignored). Never commit real keys.
WARDEN_BRAIN_API_KEY=
WARDEN_BRAIN_BASE_URL=          # e.g. https://glm-5-2.completions.near.ai/v1 direct, or https://cloud-api.near.ai/v1 gateway
WARDEN_BRAIN_DIAGNOSE_MODEL=    # e.g. z-ai/glm-5.2
WARDEN_BRAIN_VERIFY_MODEL=      # e.g. z-ai/glm-5.2

# Optional knobs
WARDEN_BRAIN_STRUCTURED_OUTPUT=json_object   # json_schema | json_object | prompt
WARDEN_BRAIN_STREAM=1

# Optional overrides
WARDEN_DB_PATH=~/.warden/warden.db
WARDEN_CLAUDE_PROJECTS=~/.claude/projects
